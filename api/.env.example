NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000
WEB_URL=http://localhost:5173
# Comma separated. Include the web dev server's own origin (WEB_URL) so a
# browser running `npm run dev` in web/ can call this API directly; in
# production the web app is served same origin via the Nginx proxy, so this
# matters for local development, not production.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

DATABASE_URL='postgres://...'
REDIS_URL='redis://...'

RABBITMQ_USER=rmq_user
RABBITMQ_PASSWORD=rmq_password
RABBITMQ_URL=http://miks-rabbitmq-5064e6-37-27-191-181.sslip.io

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MINUTES=15
AUTH_VERIFICATION_TOKEN_EXPIRY_MINUTES=15

COOKIE_DOMAIN=
COOKIE_SECURE=false

GROUP_INVITE_EXPIRY_DAYS=7

RESEND_API_KEY=
RESEND_DOMAIN=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://${APP_URL}/auth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://${APP_URL}/auth/facebook/callback
