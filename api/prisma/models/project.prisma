enum ProjectStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  CLOSED

  @@map("project_status")
}

model Project {
  id              String        @id @default(uuid())
  groupId         String        @map("group_id")
  group           Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  proposedById    String        @map("proposed_by")
  proposedBy      GroupMember   @relation(fields: [proposedById], references: [id])
  requestedBudget Decimal       @map("requested_budget") @db.Decimal(18, 2)
  sourceVaultId   String?       @map("source_vault_id")
  sourceVault     Vault?        @relation("ProjectSourceVault", fields: [sourceVaultId], references: [id])
  payoutVaultId   String?       @map("payout_vault_id")
  payoutVault     Vault?        @relation("ProjectPayoutVault", fields: [payoutVaultId], references: [id])
  status          ProjectStatus @default(PENDING)
  metadata        Json          @default("{}")
  createdAt       DateTime      @default(now()) @map("created_at")

  projectVaults Vault[] @relation("VaultOfProject")
  votes         Vote[]

  @@map("projects")
}

enum VaultType {
  GROUP
  WITHDRAWABLE
  PROJECT

  @@map("vault_type")
}

model Vault {
  id      String    @id @default(uuid())
  groupId String    @map("group_id")
  group   Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  type    VaultType
  name    String

  memberId String?      @unique @map("member_id")
  member   GroupMember? @relation(fields: [memberId], references: [id])

  projectId String?  @map("project_id")
  project   Project? @relation("VaultOfProject", fields: [projectId], references: [id])

  cachedBalance Decimal  @default(0) @map("cached_balance") @db.Decimal(18, 2)
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")

  projectsAsSourceVault Project[]         @relation("ProjectSourceVault")
  projectsAsPayoutVault Project[]         @relation("ProjectPayoutVault")
  transactions          Transaction[]
  flowDestinations      FlowDestination[]

  @@map("vaults")
}
