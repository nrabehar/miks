enum AppRoleType {
  ADMIN
  USER
}

model User {
  id          String      @id @default(uuid())
  email       String?     @unique @db.VarChar(255)
  phone       String?     @unique @db.VarChar(32)
  displayName String      @map("display_name")
  metadata    Json        @default("{}")
  createdAt   DateTime    @default(now()) @map("created_at")
  role        AppRoleType @default(USER)

  identities              UserIdentity[]
  verificationTokens      VerificationToken[]
  sessions                Session[]
  devices                 Device[]
  groupsCreated           Group[]                  @relation("GroupCreator")
  memberships             GroupMember[]
  transactionsCreated     Transaction[]
  auditLogActions         AuditLog[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  kycVerifications        KycVerification[]

  @@map("users")
}

enum AuthProviderCategory {
  LOCAL
  OAUTH

  @@map("auth_provider_category")
}

model AuthProvider {
  id       String               @id @default(uuid())
  code     String               @unique @db.VarChar(32)
  name     String
  category AuthProviderCategory
  active   Boolean              @default(true)
  config   Json                 @default("{}")

  identities UserIdentity[]

  @@map("auth_providers")
}

model UserIdentity {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerCode String       @map("provider_code") @db.VarChar(32)
  provider     AuthProvider @relation(fields: [providerCode], references: [code])

  identifier String?
  secretHash String? @map("secret_hash")

  providerAccountId String?   @map("provider_account_id")
  accessToken       String?   @map("access_token") @db.Text
  refreshToken      String?   @map("refresh_token") @db.Text
  tokenExpiresAt    DateTime? @map("token_expires_at")

  emailVerified Boolean   @default(false) @map("email_verified")
  lastUsedAt    DateTime? @map("last_used_at")
  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now()) @map("created_at")

  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")

  verificationTokens VerificationToken[]

  @@unique([providerCode, providerAccountId])
  @@unique([providerCode, identifier])
  @@index([userId])
  @@map("user_identities")
}

model VerificationTokenPurpose {
  id          String  @id @default(uuid())
  code        String  @unique @db.VarChar(32)
  name        String
  description String?

  tokens VerificationToken[]

  @@map("verification_token_purposes")
}

model VerificationToken {
  id          String                   @id @default(uuid())
  userId      String                   @map("user_id")
  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  purposeCode String                   @map("purpose_code") @db.VarChar(32)
  purpose     VerificationTokenPurpose @relation(fields: [purposeCode], references: [code])
  identityId  String?                  @map("identity_id")
  identity    UserIdentity?            @relation(fields: [identityId], references: [id], onDelete: Cascade)

  sentTo String? @map("sent_to")

  tokenHash   String    @map("token_hash")
  attempts    Int       @default(0)
  maxAttempts Int       @default(5) @map("max_attempts")
  expiresAt   DateTime  @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  metadata    Json      @default("{}")

  @@index([userId, purposeCode])
  @@index([tokenHash])
  @@map("verification_tokens")
}

enum DeviceType {
  MOBILE
  TABLET
  DESKTOP
  WEB
  OTHER

  @@map("device_type")
}

enum DeviceStatus {
  ACTIVE
  REVOKED

  @@map("device_status")
}

model Device {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         DeviceType
  platform     String?
  deviceName   String?      @map("device_name")
  deviceId     String       @map("device_id")
  pushToken    String?      @map("push_token") @db.Text
  status       DeviceStatus @default(ACTIVE)
  firstSeenAt  DateTime     @default(now()) @map("first_seen_at")
  lastActiveAt DateTime     @default(now()) @map("last_active_at")
  metadata     Json         @default("{}")

  sessions Session[]

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("devices")
}

model Session {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId     String?   @map("device_id")
  device       Device?   @relation(fields: [deviceId], references: [id])
  refreshToken String    @unique @map("refresh_token")
  userAgent    String?   @map("user_agent")
  ip           String?
  createdAt    DateTime  @default(now()) @map("created_at")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")

  @@index([userId])
  @@index([deviceId])
  @@map("sessions")
}
