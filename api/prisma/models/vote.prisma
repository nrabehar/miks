enum VoteStatus {
  OPEN
  APPROVED
  REJECTED
  INVALID

  @@map("vote_status")
}

model Vote {
  id                String     @id @default(uuid())
  projectId         String     @map("project_id")
  project           Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvalThreshold Decimal    @map("approval_threshold") @db.Decimal(5, 2)
  minQuorum         Int        @map("min_quorum")
  durationHours     Int        @map("duration_hours")
  openedAt          DateTime   @default(now()) @map("opened_at")
  scheduledCloseAt  DateTime   @map("scheduled_close_at")
  actualCloseAt     DateTime?  @map("actual_close_at")
  status            VoteStatus @default(OPEN)
  metadata          Json       @default("{}")

  responses VoteResponse[]

  @@map("votes")
}

enum VoteChoice {
  FOR
  AGAINST
  ABSTAIN

  @@map("vote_choice")
}

model VoteResponse {
  id       String      @id @default(uuid())
  voteId   String      @map("vote_id")
  vote     Vote        @relation(fields: [voteId], references: [id], onDelete: Cascade)
  memberId String      @map("member_id")
  member   GroupMember @relation(fields: [memberId], references: [id])
  choice   VoteChoice
  votedAt  DateTime    @default(now()) @map("voted_at")

  @@unique([voteId, memberId])
  @@map("vote_responses")
}
