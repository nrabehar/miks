enum VoteStatus {
  OPEN
  APPROVED
  REJECTED
  INVALID

  @@map("vote_status")
}

enum VoteSubjectType {
  PROJECT
  MEMBER_REMOVAL

  @@map("vote_subject_type")
}

model Vote {
  id                String          @id @default(uuid())
  subjectType       VoteSubjectType @default(PROJECT) @map("subject_type")
  groupId           String          @map("group_id")
  group             Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  projectId         String?         @map("project_id")
  project           Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  targetMemberId    String?         @map("target_member_id")
  targetMember      GroupMember?    @relation("VoteTarget", fields: [targetMemberId], references: [id])
  approvalThreshold Decimal         @map("approval_threshold") @db.Decimal(5, 2)
  minQuorum         Int             @map("min_quorum")
  durationHours     Int             @map("duration_hours")
  openedAt          DateTime        @default(now()) @map("opened_at")
  scheduledCloseAt  DateTime        @map("scheduled_close_at")
  actualCloseAt     DateTime?       @map("actual_close_at")
  status            VoteStatus      @default(OPEN)
  metadata          Json            @default("{}")

  responses VoteResponse[]

  // A migration-level CHECK constraint enforces exactly one of projectId /
  // targetMemberId set, matching subjectType (Prisma schema cannot express
  // a conditional constraint across columns).
  @@map("votes")
}

enum VoteChoice {
  FOR
  AGAINST
  ABSTAIN

  @@map("vote_choice")
}

model VoteResponse {
  id       String      @id @default(uuid())
  voteId   String      @map("vote_id")
  vote     Vote        @relation(fields: [voteId], references: [id], onDelete: Cascade)
  memberId String      @map("member_id")
  member   GroupMember @relation(fields: [memberId], references: [id])
  choice   VoteChoice
  votedAt  DateTime    @default(now()) @map("voted_at")

  @@unique([voteId, memberId])
  @@map("vote_responses")
}
