{
  "monorepo": true,
  "projects": {
    "api": {
      "tool": "jest",
      "gate": null,
      "additionalTools": [],
      "e2eTool": "none",
      "testDir": "beside the source",
      "filePattern": "*.spec.ts",
      "packageManager": "npm"
    },
    "web": {
      "tool": "vitest",
      "gate": null,
      "additionalTools": ["@testing-library/react", "@testing-library/user-event"],
      "e2eTool": "none",
      "testDir": "beside the source",
      "filePattern": "*.test.ts / *.test.tsx",
      "packageManager": "npm"
    }
  }
}
