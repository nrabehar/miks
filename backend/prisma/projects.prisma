model Project {
  id            String   @id @default(cuid())
  workspaceId   String
  proposedById  String
  sourceVaultId String?
  title         String
  description   String
  budget        Decimal? @db.Decimal(14, 2)
  currency      String   @default("MGA")
  status        String   @default("PENDING_VOTE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  proposedBy    WorkspaceMember   @relation(fields: [proposedById], references: [id])
  sourceVault   Vault?            @relation("ProjectSourceVault", fields: [sourceVaultId], references: [id])
  projectVaults ProjectVault[]
  fluxRules     ProjectFluxRule[]
  vote          Vote?

  @@index([workspaceId, status])
  @@map("projects")
}

model ProjectVault {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  balance     Decimal  @default(0) @db.Decimal(14, 2)
  currency    String   @default("MGA")
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_vaults")
}

model ProjectFluxRule {
  id           String   @id @default(cuid())
  projectId    String
  name         String
  sourceType   String
  isActive     Boolean  @default(true)
  destinations Json
  createdAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_flux_rules")
}
