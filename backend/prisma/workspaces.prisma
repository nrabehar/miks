model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?
  currency    String   @default("MGA")
  creatorId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator                  User                      @relation("WorkspaceCreator", fields: [creatorId], references: [id])
  members                  WorkspaceMember[]
  inviteTokens             InviteToken[]
  vaults                   Vault[]
  memberWithdrawableVaults MemberWithdrawableVault[]
  fluxRules                FluxRule[]
  projects                 Project[]
  votes                    Vote[]
  cotisations              Cotisation[]
  ledgerEntries            LedgerEntry[]
  auditLogs                AuditLog[]
  notifications            Notification[]

  @@index([slug])
  @@map("workspaces")
}

model WorkspaceMember {
  id           String   @id @default(cuid())
  workspaceId  String
  userId       String
  totalShares  Decimal  @default(0) @db.Decimal(14, 2)
  sharePercent Decimal  @default(0) @db.Decimal(7, 4)
  joinedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace         Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawableVault MemberWithdrawableVault?
  cotisations       Cotisation[]
  invitesCreated    InviteToken[]
  projectsProposed  Project[]
  voteChoices       VoteChoice[]

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

model InviteToken {
  id          String    @id @default(cuid())
  workspaceId String
  createdById String
  token       String    @unique @default(cuid())
  email       String?
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy WorkspaceMember @relation(fields: [createdById], references: [id])

  @@index([token])
  @@index([workspaceId])
  @@index([email])
  @@map("invite_tokens")
}
