// ─── 3-Vault Configuration (C1 Liquidité / C2 Investissement / C3 Sécurité) ──

model VaultConfig {
    id          String  @id @default(cuid())
    workspaceId String  @unique
    c1Ratio     Decimal @default(60) @db.Decimal(5, 2)
    c2Ratio     Decimal @default(30) @db.Decimal(5, 2)
    c3Ratio     Decimal @default(10) @db.Decimal(5, 2)

    updatedAt DateTime @updatedAt

    workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

    @@map("vault_configs")
}

// ─── Cotisations & Equity Engine (C01 / C02 / C03) ───────────────────────────

model Cotisation {
    id            String    @id @default(cuid())
    workspaceId   String
    memberId      String
    amount        Decimal   @db.Decimal(12, 2)
    currency      String    @default("MGA")
    month         Int
    year          Int
    validatedAt   DateTime?
    validatedById String?
    note          String?

    createdAt DateTime @default(now())

    workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
    member    WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

    @@unique([workspaceId, memberId, month, year])
    @@index([workspaceId])
    @@index([memberId])
    @@index([workspaceId, year, month])
    @@map("cotisations")
}

// ─── Grand Livre Numérique Immuable (T01) ────────────────────────────────────

model LedgerEntry {
    id          String  @id @default(cuid())
    workspaceId String
    type        String  // IN | OUT
    vault       String  // C1 | C2 | C3
    category    String  // COTISATION | LOAN_OUT | LOAN_IN | DIVIDEND | EXPENSE | RESERVE
    amount      Decimal @db.Decimal(12, 2)
    currency    String  @default("MGA")
    description String?
    referenceId String?
    authorId    String

    createdAt DateTime @default(now())

    workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

    @@index([workspaceId])
    @@index([workspaceId, vault])
    @@index([workspaceId, createdAt])
    @@index([referenceId])
    @@map("ledger_entries")
}

// ─── Invite Tokens (W01 / W02) ───────────────────────────────────────────────

model InviteToken {
    id          String    @id @default(cuid())
    workspaceId String
    token       String    @unique @default(cuid())
    role        String    @default("member")
    email       String?
    usedAt      DateTime?
    expiresAt   DateTime

    createdAt DateTime @default(now())

    workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

    @@index([workspaceId])
    @@index([token])
    @@map("invite_tokens")
}
