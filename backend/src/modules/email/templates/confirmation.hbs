<!DOCTYPE html>
<html lang="{{lang}}">
<head>
  <meta charset="utf-8">
  <title>{{t subjectKey}}</title>
  {{> styles }}
  <style>
    .otp-container { text-align: center; margin-bottom: 24px; }
    .otp-code { font-size: 36px; font-weight: 700; color: #2563eb; background-color: #f1f5f9; padding: 20px; border-radius: 8px; letter-spacing: 12px; font-family: "Courier New", Courier, monospace; display: inline-block; margin: 0 auto; }
    .warning-text { font-size: 14px; font-weight: 600; color: #ea580c; margin-bottom: 24px; text-align: center; }
    .notice-text { font-size: 13px; color: #64748b; text-align: center; }
  </style>
</head>
<body>
  <div class="container">
    <div class="logo-area">
      <span class="logo-text">Miks<span class="logo-dot">.</span></span>
    </div>

    <h1 class="header">{{t titleKey name=name}}</h1>
    
    <p class="text" style="white-space: pre-line;">{{t descKey name=name extraDetails=extraDetails}}</p>

    <div class="otp-container">
      <div class="otp-code">{{code}}</div>
    </div>

    <p class="warning-text">{{t 'common.warning_expiration' expirationTime=expirationTime}}</p>
    <p class="notice-text">{{t 'common.security_notice'}}</p>

    {{> footer }}
  </div>
</body>
</html>