{
	"$schema": "https://json.schemastore.org/nest-cli",
	"collection": "@nestjs/schematics",
	"sourceRoot": "src",
	"compilerOptions": {
		"deleteOutDir": true,
		"assets": [
			{
				"include": "generated/**/*",
				"outDir": "dist/src"
			},
			{
				"include": "modules/email/templates/**/*.hbs",
				"outDir": "dist/src"
			},
			{
        "include": "modules/email/i18n/**/*.json",
        "outDir": "dist/src"
      }
		],
		"watchAssets": true
	}
}
